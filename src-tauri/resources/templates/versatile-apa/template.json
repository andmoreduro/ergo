{
  "$schema": "../../schemas/ergo-template.schema.json",
  "template": {
    "id": "versatile-apa",
    "name": "APA 7th Edition",
    "version": "1.1.0",
    "description": "American Psychological Association 7th Edition formatting via the versatile-apa Typst package."
  },
  "variants": [
    {
      "id": "student",
      "label": "Student paper",
      "description": "For course assignments. Page numbers in the header; no running head or author note on the title page.",
      "default": true
    },
    {
      "id": "professional",
      "label": "Professional paper",
      "description": "For journal or publication manuscripts. Running head in the header and an author note on the title page."
    },
    {
      "id": "complete",
      "label": "Complete",
      "description": "Shows every template field (student and professional) in the editor. Preview uses the student layout."
    }
  ],
  "package": {
    "name": "@preview/versatile-apa",
    "version": "7.2.0",
    "imports": [
      "abstract-page",
      "appendix",
      "appendix-outline",
      "title-page",
      "apa-figure",
      { "symbol": "versatile-apa", "alias": "apa-style" }
    ]
  },
  "element_overrides": {
    "figure": {
      "wrapper": "apa-figure",
      "extra_fields": [
        {
          "key": "width",
          "type": "length",
          "label": "Image width"
        },
        {
          "key": "caption",
          "type": "content",
          "label": "Caption"
        },
        {
          "key": "note",
          "type": "content",
          "label": "Note"
        },
        {
          "key": "specific-note",
          "type": "content",
          "label": "Specific note"
        },
        {
          "key": "probability-note",
          "type": "content",
          "label": "Probability note (significance symbols, e.g. * p < .05)"
        }
      ]
    },
    "table": {
      "wrapper": "apa-figure",
      "extra_fields": [
        {
          "key": "caption",
          "type": "content",
          "label": "Caption"
        },
        {
          "key": "note",
          "type": "content",
          "label": "Note"
        },
        {
          "key": "specific-note",
          "type": "content",
          "label": "Specific note"
        },
        {
          "key": "probability-note",
          "type": "content",
          "label": "Probability note (significance symbols, e.g. * p < .05)"
        }
      ]
    }
  },
  "show_rule": {
    "function": "apa-style",
    "params": [
      {
        "key": "font-size",
        "type": "length",
        "source": "settings.font_size",
        "default": "12pt"
      },
      {
        "key": "running-head",
        "type": "content",
        "source": "inputs.running_head",
        "variants": ["professional"]
      }
    ]
  },
  "inputs": [
    {
      "id": "title",
      "type": "string",
      "label": "Document Title",
      "importance": "recommended",
      "default": "Untitled Document"
    },
    {
      "id": "running_head",
      "type": "string",
      "label": "Running Head",
      "importance": "recommended",
      "variants": ["professional"]
    },
    {
      "id": "abstract_text",
      "type": "content",
      "label": "Abstract",
      "importance": "recommended"
    },
    {
      "id": "keywords",
      "type": "simple_list",
      "label": "Keywords",
      "importance": "recommended",
      "items": {
        "type": "string",
        "label": "Keyword"
      }
    },
    {
      "id": "affiliations",
      "type": "simple_list",
      "label": "Affiliations",
      "importance": "recommended",
      "items": {
        "type": "content",
        "label": "Affiliation"
      }
    },
    {
      "id": "authors",
      "type": "array",
      "label": "Authors",
      "importance": "required",
      "items": {
        "type": "object",
        "properties": [
          {
            "id": "name",
            "type": "string",
            "label": "Name",
            "importance": "required"
          },
          {
            "id": "affiliations",
            "type": "array",
            "label": "Author's affiliations",
            "importance": "recommended",
            "items": {
              "type": "reference",
              "target": "affiliations",
              "label": "Affiliation Reference"
            }
          }
        ]
      }
    },
    {
      "id": "course",
      "type": "string",
      "label": "Course",
      "importance": "recommended",
      "variants": ["student"]
    },
    {
      "id": "instructor",
      "type": "string",
      "label": "Instructor",
      "importance": "recommended",
      "variants": ["student"]
    },
    {
      "id": "due_date",
      "type": "string",
      "label": "Due Date",
      "importance": "recommended",
      "variants": ["student"]
    },
    {
      "id": "author_note",
      "type": "content",
      "label": "Author Note",
      "importance": "recommended",
      "variants": ["professional"]
    }
  ],
  "groups": [
    {
      "id": "cover_page",
      "label": "Cover Page",
      "inputs": [
        "title",
        "running_head",
        "authors",
        "affiliations",
        "course",
        "instructor",
        "due_date",
        "author_note"
      ]
    },
    {
      "id": "abstract",
      "label": "Abstract & Keywords",
      "inputs": ["abstract_text", "keywords"]
    }
  ],
  "resource_policy": {
    "preview": {
      "width_pt": 360,
      "margin_pt": 8
    },
    "pasted_image": {
      "behavior": "figure",
      "wrapper": "apa-figure"
    }
  },
  "sections": [
    {
      "id": "title-page",
      "kind": "function_call",
      "function": "title-page",
      "label": "Title Page",
      "params": [
        {
          "key": "authors",
          "type": "author_list",
          "source": "inputs.authors"
        },
        {
          "key": "affiliations",
          "type": "affiliation_map",
          "source": "inputs.affiliations"
        },
        {
          "key": "course",
          "type": "content",
          "source": "inputs.course",
          "variants": ["student"]
        },
        {
          "key": "instructor",
          "type": "content",
          "source": "inputs.instructor",
          "variants": ["student"]
        },
        {
          "key": "due-date",
          "type": "content",
          "source": "inputs.due_date",
          "variants": ["student"]
        },
        {
          "key": "author-note",
          "type": "content",
          "source": "inputs.author_note",
          "variants": ["professional"]
        }
      ]
    },
    {
      "id": "abstract-page",
      "kind": "function_call",
      "function": "abstract-page",
      "label": "Abstract",
      "params": [
        {
          "key": "_positional",
          "type": "content",
          "source": "inputs.abstract_text"
        },
        {
          "key": "keywords",
          "type": "string_array",
          "source": "inputs.keywords"
        }
      ]
    },
    {
      "id": "front-matter-outlines",
      "kind": "literal",
      "label": "Outlines",
      "source": "#outline()\n#pagebreak()\n#outline(target: figure.where(kind: table), title: [Tables])\n#pagebreak()\n#outline(target: figure.where(kind: image), title: [Figures])\n#pagebreak()\n#outline(target: figure.where(kind: math.equation), title: [Equations])\n#pagebreak()\n#outline(target: figure.where(kind: raw), title: [Listings])\n#pagebreak()\n#appendix-outline(title: [Appendices])\n#pagebreak()\n"
    },
    {
      "id": "body",
      "kind": "content",
      "label": "Body"
    },
    {
      "id": "references",
      "kind": "bibliography",
      "label": "References",
      "file": "references.bib",
      "title": "References",
      "pagebreak_before": true
    },
    {
      "id": "appendices",
      "kind": "appendix",
      "label": "Appendices",
      "show_rule": "appendix"
    }
  ],
  "defaults": {
    "paper_size": "us-letter",
    "language": "en",
    "text_font": "Libertinus Serif",
    "math_font": "Libertinus Math",
    "raw_font": "DejaVu Sans Mono",
    "font_size": 12.0,
    "table_stroke_width": 0.5
  }
}

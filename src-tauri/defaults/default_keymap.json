{
  "keymap_profile": "Default",
  "keymap_bindings": [
    {
      "action_id": "workspace::NewProject",
      "context": "app",
      "sequence": [{ "key": "n", "modifiers": ["Control"] }]
    },
    {
      "action_id": "workspace::OpenProject",
      "context": "app",
      "sequence": [
        { "key": "o", "modifiers": ["Control"] },
        { "key": "o", "modifiers": ["Control"] }
      ]
    },
    {
      "action_id": "workspace::OpenRecentProject",
      "context": "app",
      "sequence": [
        { "key": "o", "modifiers": ["Control"] },
        { "key": "r", "modifiers": ["Control"] }
      ]
    },
    {
      "action_id": "workspace::SaveProject",
      "context": "workspace && !input",
      "sequence": [{ "key": "s", "modifiers": ["Control"] }]
    },
    {
      "action_id": "workspace::CloseProject",
      "context": "workspace",
      "sequence": [{ "key": "w", "modifiers": ["Control", "Shift"] }]
    },
    {
      "action_id": "view::OpenCommandPalette",
      "context": "app",
      "sequence": [{ "key": "p", "modifiers": ["Control", "Shift"] }]
    },
    {
      "action_id": "edit::Undo",
      "context": "workspace || editor || body",
      "sequence": [{ "key": "z", "modifiers": ["Control"] }]
    },
    {
      "action_id": "edit::Redo",
      "context": "workspace || editor || body",
      "sequence": [{ "key": "z", "modifiers": ["Control", "Shift"] }]
    },
    {
      "action_id": "editor::InsertParagraph",
      "context": "editor && !input",
      "sequence": [{ "key": "p", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::InsertHeading",
      "context": "editor && !input",
      "sequence": [{ "key": "h", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::InsertTable",
      "context": "editor && !input",
      "sequence": [{ "key": "t", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::InsertEquation",
      "context": "editor && !input",
      "sequence": [{ "key": "e", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::InsertFigure",
      "context": "editor && !input",
      "sequence": [{ "key": "f", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::ConvertToParagraph",
      "context": "element && !input",
      "sequence": [{ "key": "1", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::ConvertToHeading",
      "context": "element && !input",
      "sequence": [{ "key": "2", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::ConvertToTable",
      "context": "element && !input",
      "sequence": [{ "key": "3", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::ConvertToEquation",
      "context": "element && !input",
      "sequence": [{ "key": "4", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::ConvertToFigure",
      "context": "element && !input",
      "sequence": [{ "key": "5", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::Bold",
      "context": "input",
      "sequence": [{ "key": "b", "modifiers": ["Control"] }]
    },
    {
      "action_id": "editor::Italic",
      "context": "input",
      "sequence": [{ "key": "i", "modifiers": ["Control"] }]
    },
    {
      "action_id": "editor::Underline",
      "context": "input",
      "sequence": [{ "key": "u", "modifiers": ["Control"] }]
    },
    {
      "action_id": "editor::MoveTableCellLeft",
      "context": "body && input",
      "sequence": [{ "key": "arrowleft", "modifiers": ["Alt"] }]
    },
    {
      "action_id": "editor::MoveTableCellRight",
      "context": "body && input",
      "sequence": [{ "key": "arrowright", "modifiers": ["Alt"] }]
    },
    {
      "action_id": "editor::MoveTableCellUp",
      "context": "body && input",
      "sequence": [{ "key": "arrowup", "modifiers": ["Alt"] }]
    },
    {
      "action_id": "editor::MoveTableCellDown",
      "context": "body && input",
      "sequence": [{ "key": "arrowdown", "modifiers": ["Alt"] }]
    },
    {
      "action_id": "editor::AddTableRow",
      "context": "body && input",
      "sequence": [{ "key": "r", "modifiers": ["Control", "Alt", "Shift"] }]
    },
    {
      "action_id": "editor::AddTableColumn",
      "context": "body && input",
      "sequence": [{ "key": "c", "modifiers": ["Control", "Alt", "Shift"] }]
    },
    {
      "action_id": "editor::RemoveTableRow",
      "context": "body && input",
      "sequence": [{ "key": "r", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::RemoveTableColumn",
      "context": "body && input",
      "sequence": [{ "key": "c", "modifiers": ["Control", "Alt"] }]
    },
    {
      "action_id": "editor::EnterTable",
      "context": "body",
      "sequence": [{ "key": "enter", "modifiers": ["Control"] }]
    },
    {
      "action_id": "editor::Tab",
      "context": "body",
      "sequence": [{ "key": "tab", "modifiers": [] }]
    },
    {
      "action_id": "editor::Tab",
      "context": "body",
      "sequence": [{ "key": "tab", "modifiers": ["Control", "Shift"] }]
    },
    {
      "action_id": "editor::Tab",
      "context": "editor",
      "sequence": [{ "key": "tab", "modifiers": ["Control", "Shift"] }]
    },
    {
      "action_id": "editor::Tab",
      "context": "editor && input",
      "sequence": [{ "key": "tab", "modifiers": ["Control"] }]
    }
  ],
  "keymap_overrides": []
}

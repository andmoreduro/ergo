{
  "$schema": "../../schemas/ergo-template.schema.json",
  "metadata": {
    "id": "umb-apa",
    "name": "UMB's APA7",
    "version": "1.0.0",
    "description": "UMB APA 7th Edition graduate work aligned with the UMB Biblioteca guía resumida (APA 7)."
  },
  "typst": {
    "package": {
      "name": "/umb-apa/lib.typ",
      "version": "",
      "imports": [
        "front-matter",
        "appendix",
        "appendix-outline",
        "apa-figure",
        "apa-style"
      ]
    },
    "default_template_overrides": [
      { "key": "outline.include_tables", "value": "false" },
      { "key": "outline.include_figures", "value": "false" },
      { "key": "outline.include_equations", "value": "false" },
      { "key": "outline.include_listings", "value": "false" }
    ],
    "element_overrides": {
      "figure": {
        "wrapper": "apa-figure",
        "extra_fields": [
          { "key": "width", "type": "length", "label": "Image width" },
          { "key": "caption", "type": "content", "label": "Caption" },
          { "key": "note", "type": "content", "label": "Note" },
          { "key": "specific-note", "type": "content", "label": "Specific note" },
          { "key": "probability-note", "type": "content", "label": "Probability note (significance symbols, e.g. * p < .05)" }
        ]
      },
      "table": {
        "wrapper": "apa-figure",
        "extra_fields": [
          { "key": "caption", "type": "content", "label": "Caption" },
          { "key": "note", "type": "content", "label": "Note" },
          { "key": "specific-note", "type": "content", "label": "Specific note" },
          { "key": "probability-note", "type": "content", "label": "Probability note (significance symbols, e.g. * p < .05)" }
        ]
      }
    },
    "show_rule": {
      "function": "apa-style",
      "params": [
        { "key": "font-size", "type": "length", "source": "settings.font_size", "default": "12pt" }
      ]
    },
    "sections": [
      {
        "id": "front-matter",
        "kind": "function_call",
        "function": "front-matter",
        "label": "Front Matter",
        "params": [
          { "key": "title", "type": "content", "source": "inputs.title" },
          { "key": "authors", "type": "author_list", "source": "inputs.authors" },
          { "key": "affiliations", "type": "affiliation_map", "source": "inputs.affiliations" },
          { "key": "degrees", "type": "degree_map", "source": "inputs.degrees" },
          { "key": "director", "type": "dictionary", "source": "inputs.director" },
          { "key": "city", "type": "content", "source": "inputs.city" },
          { "key": "country", "type": "content", "source": "inputs.country" },
          { "key": "year", "type": "content", "source": "inputs.year" },
          { "key": "authorities", "type": "dictionary", "source": "inputs.authorities" },
          { "key": "acknowledgements", "type": "content_array", "source": "inputs.acknowledgements" },
          { "key": "abstract-es", "type": "content_array", "source": "inputs.abstract_es" },
          { "key": "keywords-es", "type": "string_array", "source": "inputs.keywords_es" },
          { "key": "abstract-en", "type": "content_array", "source": "inputs.abstract_en" },
          { "key": "keywords-en", "type": "string_array", "source": "inputs.keywords_en" }
        ]
      },
      { "id": "front-matter-outlines", "kind": "outlines", "label": "Outlines" },
      { "id": "body", "kind": "content", "label": "Body" },
      { "id": "references", "kind": "bibliography", "label": "References", "file": "references.bib", "title": "References", "pagebreak_before": true },
      { "id": "appendices", "kind": "appendix", "label": "Appendices", "show_rule": "appendix" }
    ]
  },
  "editor": {
    "inputs": [
      { "id": "title", "type": "string", "label": "Document Title", "importance": "recommended", "default": "Untitled Document" },
      {
        "id": "authors", "type": "array", "label": "Authors", "importance": "required",
        "items": {
          "id": "author", "type": "object", "label": "Author",
          "properties": [
            { "id": "name", "type": "string", "label": "Name", "importance": "required" },
            {
              "id": "affiliations", "type": "array", "label": "Author's affiliations", "importance": "recommended",
              "items": { "type": "reference", "target": "affiliations", "label": "Affiliation Reference" }
            },
            {
              "id": "degrees", "type": "array", "label": "Author's degrees", "importance": "recommended",
              "items": { "type": "reference", "target": "degrees", "label": "Degree Reference" }
            }
          ]
        }
      },
      { "id": "affiliations", "type": "simple_list", "label": "Affiliations", "importance": "recommended", "items": { "type": "content", "label": "Affiliation" } },
      { "id": "degrees", "type": "simple_list", "label": "Degrees", "importance": "recommended", "items": { "type": "content", "label": "Degree" } },
      {
        "id": "director", "type": "object", "label": "Director", "importance": "recommended",
        "properties": [
          { "id": "name", "type": "string", "label": "Name", "importance": "recommended" },
          { "id": "title", "type": "string", "label": "Title", "importance": "recommended" }
        ]
      },
      { "id": "city", "type": "string", "label": "City", "importance": "recommended" },
      { "id": "country", "type": "string", "label": "Country", "importance": "recommended" },
      { "id": "year", "type": "string", "label": "Year", "importance": "recommended" },
      {
        "id": "authorities", "type": "array", "label": "Authorities", "importance": "recommended",
        "items": {
          "id": "authority", "type": "object", "label": "Authority",
          "properties": [
            { "id": "name", "type": "string", "label": "Name", "importance": "required" },
            { "id": "role", "type": "string", "label": "Role", "importance": "required" }
          ]
        }
      },
      { "id": "acknowledgements", "type": "content_blocks", "label": "Acknowledgements", "importance": "recommended" },
      { "id": "abstract_es", "type": "content_blocks", "label": "Abstract (ES)", "importance": "recommended" },
      { "id": "keywords_es", "type": "simple_list", "label": "Keywords (ES)", "importance": "recommended", "items": { "type": "string", "label": "Keyword" } },
      { "id": "abstract_en", "type": "content_blocks", "label": "Abstract (EN)", "importance": "recommended" },
      { "id": "keywords_en", "type": "simple_list", "label": "Keywords (EN)", "importance": "recommended", "items": { "type": "string", "label": "Keyword" } }
    ],
    "groups": [
      {
        "id": "front_matter",
        "label": "Front Matter",
        "inputs": [
          "title", "authors", "affiliations", "degrees", "director", "city", "country", "year", "authorities", "acknowledgements", "abstract_es", "keywords_es", "abstract_en", "keywords_en"
        ]
      }
    ],
    "variants": [],
    "defaults": {
      "paper_size": "us-letter",
      "language": "es",
      "text_font": "Libertinus Serif",
      "math_font": "Libertinus Math",
      "raw_font": "DejaVu Sans Mono",
      "font_size": 12.0,
      "table_stroke_width": 0.5
    }
  }
}

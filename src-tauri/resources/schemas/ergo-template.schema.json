{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ergo-app.dev/schemas/ergo-template.schema.json",
  "title": "Érgo Template Specification",
  "description": "Describes how Érgo generates Typst source code from a structured document AST for a specific Typst template package.",
  "type": "object",
  "required": ["template", "package", "inputs", "sections"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "template": {
      "type": "object",
      "required": ["id", "name", "version"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "description": "Unique template identifier." },
        "name":        { "type": "string", "description": "Human-readable template name." },
        "version":     { "type": "string", "description": "Template spec version (semver)." },
        "description": { "type": "string", "description": "Short description." }
      }
    },
    "package": {
      "type": "object",
      "required": ["name", "version", "imports"],
      "additionalProperties": false,
      "properties": {
        "name":    { "type": "string", "description": "Typst package identifier (e.g. '@preview/versatile-apa')." },
        "version": { "type": "string", "description": "Package version." },
        "imports": {
          "type": "array",
          "items": { "$ref": "#/$defs/import_symbol" }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version", "imports"],
            "additionalProperties": false,
            "properties": {
              "name":    { "type": "string" },
              "version": { "type": "string" },
              "imports": { "type": "array", "items": { "$ref": "#/$defs/import_symbol" } }
            }
          }
        }
      }
    },
    "show_rule": {
      "type": "object",
      "required": ["function"],
      "additionalProperties": false,
      "properties": {
        "function": { "type": "string", "description": "Function name for #show: fn.with(...)." },
        "params":   { "type": "array", "items": { "$ref": "#/$defs/param" } },
        "variants": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inputs": {
      "type": "array",
      "description": "Document input variables schema definitions.",
      "items": { "$ref": "#/$defs/input_schema" }
    },
    "variants": {
      "type": "array",
      "description": "Paper variants supported by this template (e.g. APA student vs professional).",
      "items": { "$ref": "#/$defs/template_variant" }
    },
    "groups": {
      "type": "array",
      "description": "Logical groupings of inputs for organizing the UI.",
      "items": { "$ref": "#/$defs/input_group" }
    },
    "custom_elements": {
      "type": "array",
      "description": "Dynamic custom element inserts defined by the template.",
      "items": { "$ref": "#/$defs/custom_element" }
    },
    "resource_policy": {
      "$ref": "#/$defs/resource_policy"
    },
    "element_overrides": {
      "$ref": "#/$defs/element_overrides"
    },
    "sections": {
      "type": "array",
      "description": "Ordered structural sections of the document.",
      "items": { "$ref": "#/$defs/section" }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paper_size":         { "type": "string" },
        "language":           { "type": "string" },
        "text_font":          { "type": "string" },
        "math_font":          { "type": "string" },
        "raw_font":           { "type": "string" },
        "font_size":          { "type": "number" },
        "table_stroke_width": { "type": "number" }
      }
    }
  },
  "$defs": {
    "template_variant": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "label":       { "type": "string" },
        "description": { "type": "string" },
        "default":     { "type": "boolean", "default": false }
      }
    },
    "variant_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "When set, the item applies only to these variant ids. Omit for all variants."
    },
    "import_symbol": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["symbol"],
          "additionalProperties": false,
          "properties": {
            "symbol": { "type": "string" },
            "alias":  { "type": "string" }
          }
        }
      ]
    },
    "input_schema": {
      "type": "object",
      "required": ["id", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "type":        { "type": "string", "enum": ["string", "integer", "float", "boolean", "array", "object", "reference", "content", "simple_list"] },
        "label":       { "type": "string" },
        "description": { "type": "string" },
        "default":     { "description": "Default input value." },
        "importance":  { "type": "string", "enum": ["required", "recommended", "optional"], "default": "optional" },
        "variants":    { "$ref": "#/$defs/variant_ids" },
        "properties":  {
          "type": "array",
          "items": { "$ref": "#/$defs/input_schema" }
        },
        "items":       { "$ref": "#/$defs/input_schema" },
        "target":      { "type": "string", "description": "If reference type, the input ID it references (e.g. 'affiliations')." }
      }
    },
    "input_group": {
      "type": "object",
      "required": ["id", "label", "inputs"],
      "additionalProperties": false,
      "properties": {
        "id":     { "type": "string" },
        "label":  { "type": "string" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "variants": { "$ref": "#/$defs/variant_ids" }
      }
    },
    "custom_element": {
      "type": "object",
      "required": ["kind", "label", "function", "fields"],
      "additionalProperties": false,
      "properties": {
        "kind":        { "type": "string", "description": "Unique key matching custom element kind." },
        "label":       { "type": "string" },
        "description": { "type": "string" },
        "function":    { "type": "string", "description": "Typst package function to call for this element." },
        "fields":      {
          "type": "array",
          "items": { "$ref": "#/$defs/param" }
        }
      }
    },
    "element_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "figure": { "$ref": "#/$defs/element_override" },
        "table": { "$ref": "#/$defs/element_override" }
      }
    },
    "element_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "function": {
          "type": "string",
          "description": "Typst function for figure emission when wrapper is omitted (legacy)."
        },
        "wrapper": {
          "type": "string",
          "description": "Typst function wrapping table and image elements (e.g. figure, apa-figure)."
        },
        "extra_fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/extra_field" }
        }
      }
    },
    "extra_field": {
      "type": "object",
      "required": ["key", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "key":   { "type": "string" },
        "type":  { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "resource_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preview": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width_pt":  { "type": "number", "exclusiveMinimum": 0 },
            "margin_pt": { "type": "number", "minimum": 0 },
            "wrapper":   { "type": "string" }
          }
        },
        "pasted_image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "behavior": { "type": "string", "enum": ["resource", "figure"], "default": "figure" },
            "wrapper":  { "type": "string" }
          }
        }
      }
    },
    "param": {
      "type": "object",
      "required": ["key", "type"],
      "additionalProperties": false,
      "properties": {
        "key":        { "type": "string", "description": "Typst parameter name. '_positional' for positional args." },
        "type":       { "type": "string", "enum": ["content", "string", "length", "boolean", "integer", "float", "string_array", "content_array", "dictionary", "author_list", "affiliation_map"] },
        "source":     { "type": "string", "description": "Dot-path into the AST inputs/settings (e.g. 'inputs.title')." },
        "label":      { "type": "string" },
        "default":    { "description": "Default value if the AST field is empty." },
        "required":   { "type": "boolean", "default": false },
        "variants":   { "$ref": "#/$defs/variant_ids" }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id":               { "type": "string" },
        "kind":             { "type": "string", "enum": ["function_call", "literal", "content", "bibliography", "appendix"] },
        "label":            { "type": "string" },
        "function":         { "type": "string" },
        "params":           { "type": "array", "items": { "$ref": "#/$defs/param" } },
        "source":           { "type": "string", "description": "Literal Typst source for 'literal' kind." },
        "file":             { "type": "string", "description": "Bibliography file path." },
        "title":            { "type": "string" },
        "show_rule":        { "type": "string" },
        "editable":         { "type": "boolean", "default": true },
        "pagebreak_before": { "type": "boolean", "default": false },
        "variants":         { "$ref": "#/$defs/variant_ids" }
      }
    }
  }
}

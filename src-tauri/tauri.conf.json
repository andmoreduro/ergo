{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Érgo",
  "version": "0.1.0",
  "identifier": "com.ergo.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Érgo",
        "width": 1024,
        "height": 768,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' http://localhost:8097; connect-src 'self' ws://localhost:8097 http://localhost:8097; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "defaults/*",
      "resources/templates/*.ergtemplate"
    ],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
